{
  "compilerOptions": {
    "target": "es2024",
    "module": "node16",
    "moduleResolution": "node16",
    "strict": true,
    "strictNullChecks": true,
    "noImplicitAny": true,
    "esModuleInterop": true,
    "outDir": "./dist",
    "baseUrl": ".",
    "paths": {
      "@models/*": ["@cds-models/*/index.ts"],
      "@/*": ["./srv/*"]
    }
  },
  "include": ["srv", "test"],
  "exclude": ["node_modules"]
}